# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Raw product photos / videos — too big for git, served from cleaned hero
# images under /public/products/<slug>/. Mirrors .vercelignore.
public/products/*/photos/
public/products/*/videos/
public/products/raw/
public/*.mp4
public/*.MOV

# Fresh shoot raw inputs (2026-06-04). Staged for the cleaning pipeline at
# scripts/clean-fresh-shoot.py; outputs land in public/products/colors/ and
# are committed. The 187 MB of raw iPhone JPEGs are NOT.
public/fresh/

# Legacy backups of AI-generated color variants kept locally in case we need
# to revert the 2026-06-04 real-photo swap.
public/products/colors/_legacy/

# Python utility scripts artifacts
__pycache__/
*.pyc

# Private legal docs — do NOT commit to a public repo
GST*.pdf
*Certificate*.pdf
*certificate*.pdf

# Voice notes / private audio
*.ogg
WhatsApp*.ogg
public/WhatsApp*.ogg

# Scraped UGC raw videos — compressed copies ARE committed and served from /public/ugc/.
# Originals are kept under _orig/ for re-encoding and are NOT committed.
public/ugc/_orig/
public/ugc/*.raw.*

# Hero video source masters — kept at repo root for re-encoding, the optimized
# renditions ship from public/hero/. Originals are too big for git.
/Rc Cars Driving.mp4
/*.MOV
/*.mov

# Scratch directory for raw source media + one-off optimization scripts.
# Outputs land under public/ and ARE committed; the raw inputs are not.
/.scratch/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
